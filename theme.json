{
	"title": "JSON schema for WordPress block theme Govwind, settings and styles",
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "var(--size-content)",
			"wideSize": "var(--size-wide)"
		},
		"color": {
			"defaultPalette": false,
			"palette": [
				{
					"slug": "colour-Y",
					"color": "var(--colour-palette-1)",
					"name": "Primary"
				},
				{
					"slug": "colour-Z",
					"color": "var(--colour-palette-2)",
					"name": "Primary accent"
				},
				{
					"slug": "greyscale-A",
					"color": "var(--colour-palette-greyscale-1)",
					"name": "Greyscale 1"
				},
				{
					"slug": "greyscale-B",
					"color": "var(--colour-palette-greyscale-2)",
					"name": "Greyscale 2"
				},
				{
					"slug": "greyscale-Y",
					"color": "var(--colour-palette-greyscale-3)",
					"name": "Greyscale 3"
				},
				{
					"slug": "greyscale-Z",
					"color": "var(--colour-palette-greyscale-4)",
					"name": "Greyscale 4"
				}
			]
		},
		"typography": {
			"fluid": false,
			"fontSizes": [
				{ "slug": "xs", "size": "var(--font-size-xs)", "name": "Extra Small" },
				{ "slug": "sm", "size": "var(--font-size-sm)", "name": "Small" },
				{ "slug": "base", "size": "var(--font-size-base)", "name": "Base" },
				{ "slug": "lg", "size": "var(--font-size-lg)", "name": "Large" },
				{ "slug": "xl", "size": "var(--font-size-xl)", "name": "Extra Large" },
				{ "slug": "2-xl", "size": "var(--font-size-2-xl)", "name": "2X Large" },
				{ "slug": "3-xl", "size": "var(--font-size-3-xl)", "name": "3X Large" },
				{ "slug": "4-xl", "size": "var(--font-size-4-xl)", "name": "4X Large" },
				{ "slug": "5-xl", "size": "var(--font-size-5-xl)", "name": "5X Large" },
				{ "slug": "6-xl", "size": "var(--font-size-6-xl)", "name": "6X Large" },
				{ "slug": "7-xl", "size": "var(--font-size-7-xl)", "name": "7X Large" },
				{ "slug": "8-xl", "size": "var(--font-size-8-xl)", "name": "8X Large" },
				{ "slug": "9-xl", "size": "var(--font-size-9-xl)", "name": "9X Large" }
			],
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "Sans Serif",
					"fontFamily": "var(--font-family-sans)"
				},
				{
					"slug": "serif",
					"name": "Serif",
					"fontFamily": "var(--font-family-serif)"
				},
				{
					"slug": "mono",
					"name": "Monospace",
					"fontFamily": "var(--font-family-mono)"
				},
				{
					"slug": "inter",
					"name": "Inter",
					"fontFamily": "var(--font-family-inter)"
				},
				{
					"slug": "pt-sans",
					"name": "PT Sans",
					"fontFamily": "var(--font-family-pt-sans)"
				}
			]
		},
		"border": {
			"customRadius": true,
			"radius": {
				"none": "var(--radius-none)",
				"sm": "var(--radius-sm)",
				"default": "var(--radius-default)",
				"md": "var(--radius-md)",
				"lg": "var(--radius-lg)",
				"xl": "var(--radius-xl)",
				"2-xl": "var(--radius-2-xl)",
				"3-xl": "var(--radius-3-xl)",
				"full": "var(--radius-full)"
			}
		},
		"spacing": {
			"customPadding": true,
			"customMargin": true,
			"units": ["px", "rem", "%", "vh", "vw"],
			"spacingPresets": [
				{ "name": "0", "slug": "0", "size": "var(--spacing-0)" },
				{ "name": "px", "slug": "px", "size": "var(--spacing-px)" },
				{ "name": "0.5", "slug": "0-5", "size": "var(--spacing-0-5)" },
				{ "name": "1", "slug": "1", "size": "var(--spacing-1)" },
				{ "name": "1.5", "slug": "1-5", "size": "var(--spacing-1-5)" },
				{ "name": "2", "slug": "2", "size": "var(--spacing-2)" },
				{ "name": "2.5", "slug": "2-5", "size": "var(--spacing-2-5)" },
				{ "name": "3", "slug": "3", "size": "var(--spacing-3)" },
				{ "name": "3.5", "slug": "3-5", "size": "var(--spacing-3-5)" },
				{ "name": "4", "slug": "4", "size": "var(--spacing-4)" },
				{ "name": "5", "slug": "5", "size": "var(--spacing-5)" },
				{ "name": "6", "slug": "6", "size": "var(--spacing-6)" },
				{ "name": "7", "slug": "7", "size": "var(--spacing-7)" },
				{ "name": "8", "slug": "8", "size": "var(--spacing-8)" },
				{ "name": "9", "slug": "9", "size": "var(--spacing-9)" },
				{ "name": "10", "slug": "10", "size": "var(--spacing-10)" },
				{ "name": "11", "slug": "11", "size": "var(--spacing-11)" },
				{ "name": "12", "slug": "12", "size": "var(--spacing-12)" },
				{ "name": "14", "slug": "14", "size": "var(--spacing-14)" },
				{ "name": "16", "slug": "16", "size": "var(--spacing-16)" },
				{ "name": "20", "slug": "20", "size": "var(--spacing-20)" },
				{ "name": "24", "slug": "24", "size": "var(--spacing-24)" },
				{ "name": "28", "slug": "28", "size": "var(--spacing-28)" },
				{ "name": "32", "slug": "32", "size": "var(--spacing-32)" },
				{ "name": "36", "slug": "36", "size": "var(--spacing-36)" },
				{ "name": "40", "slug": "40", "size": "var(--spacing-40)" },
				{ "name": "44", "slug": "44", "size": "var(--spacing-44)" },
				{ "name": "48", "slug": "48", "size": "var(--spacing-48)" },
				{ "name": "52", "slug": "52", "size": "var(--spacing-52)" },
				{ "name": "56", "slug": "56", "size": "var(--spacing-56)" },
				{ "name": "60", "slug": "60", "size": "var(--spacing-60)" },
				{ "name": "64", "slug": "64", "size": "var(--spacing-64)" },
				{ "name": "72", "slug": "72", "size": "var(--spacing-72)" },
				{ "name": "80", "slug": "80", "size": "var(--spacing-80)" },
				{ "name": "96", "slug": "96", "size": "var(--spacing-96)" }
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--colour-page-background)",
			"text": "var(--colour-foreground)"
		},
		"spacing": {
			"blockGap": "var(--wp-block-gap)",
			"padding": {
				"top": "0",
				"bottom": "0",
				"left": "var(--wp-container-padding)",
				"right": "var(--wp-container-padding)"
			}
		},
		"typography": {
			"fontFamily": "var(--font-family-pt-sans)",
			"fontSize": "var(--font-size-base)",
			"lineHeight": "var(--line-height-normal)",
			"textAlign": "left"
		},
		"elements": {
			"body": {
				"typography": {
					"fontSize": "var(--font-size-base)",
					"fontFamily": "var(--font-family-pt-sans)",
					"lineHeight": "var(--line-height-normal)"
				}
			},
			"link": {
				"color": {
					"text": "var(--colour-link-text)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--colour-link-text-hover)"
					}
				},
				":visited": {
					"color": {
						"text": "var(--colour-link-text-visited)"
					}
				},
				":focus": {
					"color": {
						"text": "var(--colour-focus-text)!important",
						"background": "var(--colour-focus-background-muted)!important"
					},
					"shadow": "0 -0.075em var(--colour-focus-background-muted), 0 0.15em var(--colour-focus-outline)",
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus-visible": {
					"color": {
						"background": "var(--colour-focus-background)!important"
					},
					"shadow": "0 -0.075em var(--colour-focus-background), 0 0.15em var(--colour-focus-outline)",
					"outline": {
						"style": "solid",
						"color": "transparent"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--colour-button-background)",
					"text": "var(--colour-button-text)"
				},
				"border": {
					"radius": "var(--radius-md)"
				},
				"spacing": {
					"padding": {
						"top": "var(--spacing-2-5)",
						"bottom": "var(--spacing-2-5)",
						"left": "var(--spacing-4)",
						"right": "var(--spacing-4)"
					},
					"margin": {
						"top": "3px",
						"bottom": "3px",
						"left": "0",
						"right": "3px"
					}
				},
				"typography": {
					"fontSize": "var(--font-size-base)",
					"lineHeight": "1.75"
				},
				":focus": {
					"color": {
						"text": "var(--colour-focus-text)",
						"background": "var(--colour-focus-background-muted)"
					},
					"outline": {
						"color": "var(--colour-focus-outline)",
						"width": "3px",
						"style": "solid",
						"offset": "0px"
					}
				},
				":focus-visible": {
					"color": {
						"text": "var(--colour-focus-text)",
						"background": "var(--colour-focus-background)"
					},
					"outline": {
						"color": "var(--colour-focus-outline)",
						"style": "solid"
					}
				}
			}
		},
		"blocks": {
			"wb-blocks/accordion": {
				"spacing": {
					"padding": {
						"right": "var(--prose-max-width-padding)"
					}
				}
			},
			"wb-blocks/reveal": {
				"color": {
					"text": "var(--colour-foreground)"
				},
				"spacing": {
					"padding": {
						"right": "var(--prose-max-width-padding)"
					}
				}
			},
			"core/site-title": {
				"spacing": {
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					}
				},
				"typography": {
					"fontSize": "var(--font-size-3-xl)",
					"lineHeight": "var(--line-height-tight)"
				}
			},
			"core/paragraph": {
				"spacing": {
					"padding": {
						"right": "var(--prose-max-width-padding)"
					},
					"margin": {
						"top": "0",
						"right": "0",
						"left": "0"
					}
				},
				"typography": {
					"lineHeight": "var(--line-height-relaxed)"
				}
			},
			"core/navigation": {
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"bottom": "0.75rem"
					},
					"margin": {
						"right": "auto",
						"left": "auto"
					}
				},
				"typography": {
					"fontFamily": "var(--font-family-pt-sans)",
					"fontSize": "var(--font-size-base)",
					"lineHeight": "var(--line-height-normal)"
				}
			},
			"core/search": {
				"elements": {
					"button": {
						"border": {
							"radius": "var(--radius-md)"
						}
					}
				}
			},
			"core/heading": {
				"typography": {
					"fontFamily": "var(--font-family-pt-sans)",
					"fontWeight": "700",
					"lineHeight": "var(--line-height-tight)"
				}
			},
			"core/image": {
				"elements": {
					"caption": {
						"spacing": {
							"padding": {
								"right": "var(--prose-max-width-padding)"
							}
						},
						"typography": {
							"fontSize": "var(--font-size-sm)",
							"lineHeight": "var(--line-height-normal)"
						}
					}
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--colour-greyscale-2)"
				},
				"spacing": {
					"margin": {
						"top": "var(--spacing-8)",
						"bottom": "var(--spacing-8)"
					}
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--colour-quote-border)",
					"style": "solid",
					"width": "0 0 0 4px"
				},
				"spacing": {
					"padding": {
						"left": "var(--spacing-4)"
					},
					"margin": {
						"bottom": "var(--spacing-6)"
					}
				},
				"typography": {
					"fontSize": "var(--font-size-lg)",
					"fontStyle": "italic",
					"lineHeight": "var(--line-height-relaxed)"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--colour-muted)",
					"text": "var(--colour-foreground)"
				},
				"border": {
					"radius": "var(--radius-sm)"
				},
				"spacing": {
					"padding": {
						"top": "var(--spacing-1)",
						"bottom": "var(--spacing-1)",
						"left": "var(--spacing-2)",
						"right": "var(--spacing-2)"
					}
				},
				"typography": {
					"fontFamily": "var(--font-family-mono)",
					"fontSize": "var(--font-size-sm)",
					"lineHeight": "var(--line-height-relaxed)"
				}
			},
			"core/button": {
				"styleVariations": [
					{
						"name": "ghost",
						"label": "Ghost",
						"styles": {
							"color": {
								"text": "red"
							}
						}
					}
				]
			},
			"core/media-text": {
				"typography": {
					"lineHeight": "var(--line-height-normal)"
				},
				"styleVariations": [
					{
						"name": "dark-text",
						"label": "Dark Text",
						"styles": {
							"color": {
								"text": "var(--wp--preset--color--black)"
							}
						}
					}
				]
			},
			"core/list": {
				"spacing": {
					"padding": {
						"left": "1.1em",
						"right": "var(--prose-max-width-padding)"
					},
					"margin": {
						"left": "0"
					}
				},
				"typography": {
					"lineHeight": "var(--line-height-relaxed)"
				},
				"css": "list-style-type: revert; &:is(ol) { padding-left: 1.4em; }"
			},
			"core/accordion": {
				"spacing": {
					"padding": {
						"right": "var(--prose-max-width-padding)"
					}
				},
				"typography": {
					"lineHeight": "var(--line-height-normal)"
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "full-width",
			"title": "Full Width",
			"postTypes": ["page"]
		},
		{
			"name": "no-sidebar",
			"title": "No Sidebar",
			"postTypes": ["page", "post"]
		},
		{
			"name": "landing",
			"title": "Landing Page",
			"postTypes": ["page"]
		}
	],
	"patterns": [
		"fullscreen-cover-image-gallery",
		"hero-banner-with-overlap-images",
		"govwind/tip",
		"govwind/cta-centered",
		"govwind/three-cards",
		"govwind/video-with-reveal",
		"govwind/hero-cta-full-width",
		"govwind/icon-info-card",
		"govwind/feature-two-col",
		"govwind/cta",
		"govwind/about",
		"govwind/page-heading-hero",
		"govwind/icon-grid-cta",
		"govwind/toc-section"
	],
	"templateParts": [
		{
			"area": "header",
			"name": "header-no-search",
			"title": "No Search Bar Header",
			"description": "Header without search functionality - ideal for search result pages."
		},
		{
			"area": "header",
			"name": "header-default",
			"title": "Default Header",
			"description": "Standard header with navigation and logo used by most pages."
		},
		{
			"area": "header",
			"name": "header-inline",
			"title": "Inline Header",
			"description": "Standard header with navigation and logo used by most pages."
		},
		{
			"area": "header",
			"name": "header-minimal",
			"title": "Minimal Header",
			"description": "Simple header with only logo and site title - no navigation."
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Default Footer",
			"description": "Standard site footer with links and information."
		},
		{
			"area": "footer",
			"name": "footer-wide",
			"title": "Footer wide",
			"description": "Standard site footer with links and information."
		}
	]
}
